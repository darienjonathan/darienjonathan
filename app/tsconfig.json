{
  // https://v3.nuxtjs.org/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "target": "es5",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["dom", "es5", "es6", "es7", "es2019"],
    "resolveJsonModule": true,
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "types": ["@types/node"]
  },
  "compileOnSave": true,
  "exclude": ["node_modules"]
}
